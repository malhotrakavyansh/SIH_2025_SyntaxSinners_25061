NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side only (no NEXT_PUBLIC_ prefix - never sent to the browser).
# Used by app/api/verify-tibetan-ocr for AI-powered Tibetan OCR verification.
# Get one from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Server-side only. Used by app/Contributions/OCR/route.ts for English OCR
# via OCR.space. Falls back to their public "helloworld" demo key (rate-limited)
# if unset. Get a real key from https://ocr.space/ocrapi
OCR_SPACE_API_KEY=
