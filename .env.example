GEMINI_API_KEY=your_gemini_api_key_here
ALLOWED_ORIGINS=http://localhost:3000

# Razorpay test-mode keys (console.razorpay.com -> Settings -> API Keys). Key Secret
# stays server-side only - never expose it to the frontend. Without these set, booking
# payment endpoints return 503.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Secret used to sign session JWTs. Use a long random string in any real deployment -
# the fallback dev value in api.py is NOT safe to use outside local development.
JWT_SECRET=

# Comma-separated emails that get the "admin" role automatically at registration time,
# e.g. ADMIN_EMAILS=you@example.com,teammate@example.com
ADMIN_EMAILS=
